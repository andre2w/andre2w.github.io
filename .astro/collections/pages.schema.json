{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "updated": {
      "type": "string",
      "format": "date-time"
    },
    "draft": {
      "default": false,
      "type": "boolean"
    },
    "lang": {
      "type": "string"
    },
    "annotation": {
      "type": "string"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "updated"
  ]
}